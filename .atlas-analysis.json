  "keyFeatures": [
    "JWT-based authentication with refresh tokens",
    "Animal management (lost/found listings)",
    "Caregiver registration and profiles",
    "Role-based access control",
    "Image upload with Firebase Storage",
    "Email verification and password reset",
    "Zone-based filtering for animals",
    "Post/advertisement system"
  ],
  "publicApiSurface": [
    "POST /api/auth/no-auth/register",
    "POST /api/auth/no-auth/login",
    "POST /api/auth/no-auth/refresh-token",
    "POST /api/auth/no-auth/request-reset-password",
    "GET /api/animals",
